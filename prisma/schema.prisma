generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  ADMIN
  SUPER_ADMIN
  MERCHANT
}

enum ListingStatus {
  LIVE
  SAVED
  SOLD
  REVIEW
  BLOCKED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  name         String
  role         UserRole @default(STUDENT)
  countryCode  String?
  universityId String?
  trustScore   Int      @default(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile      StudentProfile?
  wallet       Wallet?
  tasks        Task[]
  deadlines    Deadline[]
  listings     MarketplaceListing[]
  auditLogs    AuditLog[]
}

model StudentProfile {
  id                    String  @id @default(cuid())
  userId                String  @unique
  course                String?
  preferredLanguage     String  @default("English")
  preferredCurrency     String  @default("GBP")
  internationalStudent  Boolean @default(false)
  timezone              String  @default("Europe/London")
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model Country {
  code               String   @id
  name               String
  region             String
  currency           String
  defaultLanguage    String
  timezone           String
  studentPrice       Decimal  @db.Decimal(10, 2)
  affordabilityIndex Int
  universities       University[]
}

model University {
  id          String  @id @default(cuid())
  name        String
  countryCode String
  domain      String  @unique
  city        String
  country     Country @relation(fields: [countryCode], references: [code])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  points    Int      @default(0)
  currency  String   @default("GBP")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger    WalletLedger[]
}

model WalletLedger {
  id        String   @id @default(cuid())
  walletId  String
  type      String
  title     String
  amount    Decimal  @db.Decimal(10, 2)
  status    String
  createdAt DateTime @default(now())
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  priority  String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deadline {
  id      String   @id @default(cuid())
  userId  String
  title   String
  dueDate DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deal {
  id         String   @id @default(cuid())
  merchant   String
  title      String
  category   String
  discount   String
  countryCode String?
  active     Boolean  @default(true)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
}

model MarketplaceListing {
  id        String        @id @default(cuid())
  userId    String
  title     String
  category  String
  price     Decimal       @db.Decimal(10, 2)
  currency  String
  status    ListingStatus @default(LIVE)
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id          String   @id @default(cuid())
  title       String
  provider    String
  type        String
  countryCode String?
  value       String
  deadline    DateTime?
  active      Boolean  @default(true)
  fieldSchema Json
  createdAt   DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  plan      String
  status    String
  currency  String
  amount    Decimal  @db.Decimal(10, 2)
  startedAt DateTime @default(now())
  endsAt    DateTime?
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  category    String
  priority    String   @default("NORMAL")
  status      String   @default("OPEN")
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    SupportTicketMessage[]
  @@index([userId])
  @@index([status])
}



model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
}

model ApiEvent {
  id        String   @id @default(cuid())
  route     String
  method    String
  status    Int
  latencyMs Int
  createdAt DateTime @default(now())
}


model AuthIdentity {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  identifier String
  verified   Boolean  @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
}

model VerificationRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("scheduled")
  evidenceUrl String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
}

model DeviceSession {
  id          String   @id @default(cuid())
  userId      String
  deviceHash  String
  deviceLabel String
  ipRisk      String
  status      String   @default("ACTIVE")
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

model LoginAudit {
  id        String   @id @default(cuid())
  userId    String?
  method    String
  location  String?
  device    String?
  result    String
  risk      String
  createdAt DateTime @default(now())
}

model FraudSignal {
  id        String   @id @default(cuid())
  userId    String?
  area      String
  signal    String
  score     Int
  severity  String
  action    String
  createdAt DateTime @default(now())
}

model IdentityRiskProfile {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  identityScore              Int      @default(500)
  fraudRisk                  String   @default("LOW")
  verifiedStudent            Boolean  @default(false)
  verificationCompletion     Int      @default(0)
  accountRecoveryEnabled     Boolean  @default(false)
  updatedAt                  DateTime @updatedAt
}


model MessageThread {
  id          String   @id @default(cuid())
  title       String
  context     String
  priority    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    Message[]
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String?
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  category  String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
}



model EmailPreference {
  id        String   @id @default(cuid())
  userId    String
  digest    String
  enabled   Boolean  @default(true)
  frequency String
  updatedAt DateTime @updatedAt
}

model SupportConversation {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("OPEN")
  priority  String   @default("MEDIUM")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpArticle {
  id        String   @id @default(cuid())
  title     String
  category  String
  body      String
  helpful   Int      @default(0)
  published Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model CommunicationCampaign {
  id        String   @id @default(cuid())
  name      String
  channel   String
  audience  String
  status    String
  sent      Int      @default(0)
  openRate  String?
