  status    String
  createdAt DateTime @default(now())
}


model SecurityEvent {
  id        String   @id @default(cuid())
  actorId   String?
  type      String
  severity  String
  source    String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model MfaEnrollment {
  id          String   @id @default(cuid())
  userId      String
  method      String
  secretHash  String
  enabled     Boolean  @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
