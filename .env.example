# UniSphere Production Environment Example

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/unisphere

# Auth
AUTH_SECRET=GENERATE_STRONG_32_BYTE_SECRET
JWT_ISSUER=unisphere
JWT_AUDIENCE=unisphere-students

# Payments
STRIPE_SECRET_KEY=sk_live_CONFIGURE_IN_PROVIDER
STRIPE_WEBHOOK_SECRET=whsec_CONFIGURE_IN_PROVIDER
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CONFIGURE_IN_PROVIDER

# Email
RESEND_API_KEY=re_CONFIGURE_IN_PROVIDER
FROM_EMAIL=UniSphere <hello@your-domain.com>

# AI Providers
OPENAI_API_KEY=sk_replace
AI_MONTHLY_BUDGET_GBP=2000

# PWA / Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace
VAPID_PRIVATE_KEY=replace

# Security / Monitoring
SENTRY_DSN=replace
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Identity / Security
OTP_HASH_SECRET=GENERATE_STRONG_OTP_HASH_SECRET
MAGIC_LINK_SECRET=GENERATE_STRONG_MAGIC_LINK_SECRET
GOOGLE_CLIENT_ID=replace
GOOGLE_CLIENT_SECRET=replace
APPLE_CLIENT_ID=replace
APPLE_CLIENT_SECRET=replace
MICROSOFT_CLIENT_ID=replace
MICROSOFT_CLIENT_SECRET=replace
LINKEDIN_CLIENT_ID=replace
LINKEDIN_CLIENT_SECRET=replace
DEVICE_FINGERPRINT_SALT=GENERATE_STRONG_DEVICE_SALT

# Communication Providers
PUSH_PROVIDER=web-push
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=replace
TWILIO_AUTH_TOKEN=replace
TWILIO_FROM_NUMBER=replace
SUPPORT_INBOX_EMAIL=support@your-domain.com


NEXT_PUBLIC_APP_URL=https://unisphere.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/unisphere?sslmode=require
AUTH_SECRET=GENERATE_STRONG_32_BYTE_SECRET
OTP_HASH_SECRET=GENERATE_STRONG_OTP_HASH_SECRET
STRIPE_SECRET_KEY=sk_live_CONFIGURE_IN_STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CONFIGURE_IN_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_CONFIGURE_IN_STRIPE
STRIPE_PRICE_STUDENT_MONTHLY=price_CONFIGURE_IN_STRIPE
RESEND_API_KEY=re_CONFIGURE_IN_RESEND
FROM_EMAIL=UniSphere <hello@unisphere.app>
OPENAI_API_KEY=sk_CONFIGURE_IN_OPENAI
AI_MAX_REQUESTS_PER_USER_PER_DAY=25
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CONFIGURE_WEB_PUSH_PUBLIC_KEY
VAPID_PRIVATE_KEY=CONFIGURE_WEB_PUSH_PRIVATE_KEY
SENTRY_DSN=CONFIGURE_IN_SENTRY


# Dynamic Pricing & Global Billing
BASE_CURRENCY=USD
DEFAULT_COUNTRY_CODE=US
DEFAULT_LANGUAGE_CODE=en
STRIPE_PRICE_STUDENT_MONTHLY=price_CONFIGURE_IN_STRIPE
STRIPE_PRICE_STUDENT_QUARTERLY=price_CONFIGURE_IN_STRIPE
STRIPE_PRICE_STUDENT_YEARLY=price_CONFIGURE_IN_STRIPE

# Functional Wiring
FX_RATE_PROVIDER=external-fx-provider
FX_RATE_API_URL=
FX_RATE_API_KEY=
VAPID_SUBJECT=mailto:support@unisphere.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=CONFIGURE_WEB_PUSH_PUBLIC_KEY
VAPID_PRIVATE_KEY=CONFIGURE_WEB_PUSH_PRIVATE_KEY

MEDIA_STORAGE_PROVIDER=

MEDIA_STORAGE_BUCKET=

MEDIA_STORAGE_ACCESS_KEY=

MEDIA_STORAGE_SECRET_KEY=

OPENAI_MODEL=

EMAIL_FROM=
